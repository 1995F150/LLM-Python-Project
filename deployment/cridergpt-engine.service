[Unit]
Description=CriderGPT Engine Service
After=network-online.target ollama.service
Wants=network-online.target

[Service]
Type=simple
User=cridergpt
Group=cridergpt
WorkingDirectory=/opt/cridergpt-engine
EnvironmentFile=/opt/cridergpt-engine/.env
ExecStart=/opt/cridergpt-engine/venv/bin/uvicorn app:app --host 127.0.0.1 --port 8000 --proxy-headers --forwarded-allow-ips=127.0.0.1
Restart=on-failure
RestartSec=5
TimeoutStopSec=30
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/cridergpt-engine/data

[Install]
WantedBy=multi-user.target

